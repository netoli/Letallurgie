  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f78bfdd03640af745a0171a3f855f488, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::RamasserIndice
  titre: "Note d\xE9chir\xE9e"
  description: "Un morceau de papier froiss\xE9, d\xE9chir\xE9 sur un c\xF4t\xE9.
    L'\xE9criture est tremblante. On peut y lire \"ne sais pas o\xF9 ils m'emm\xE8nent.
    \xC7a fait des semaines qu'on entend parler de disparitions. Je pensais que c'\xE9tait
    vrai qu...\""
  insight: "Quelqu'un a \xE9crit \xE7a en panique avant de dispara\xEEtre... Ce n'est
    pas l'\xE9criture du tavernier... Il n'est pas le premier et, si je n'agis pas,
    pas le dernier. "
  img: {fileID: 21300000, guid: db06b4ec3ad19af4596d1422d2b9a069, type: 3}
  sonRamasser: {fileID: 8300000, guid: 213de7bc57dbd8b4f920cdfeae2ccbfe, type: 3}
