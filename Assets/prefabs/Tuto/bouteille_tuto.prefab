  objetInventaire: {fileID: 11400000, guid: ad464b8dcc3565b42915da2f9ef48e2c, type: 2}
  ajouterJournal: 1
  titreJournal: Bouteille de vin au miel
  descriptionJournal: "Le fameux vin au miel de la Taverne, une recette secr\xE8te
    qui attire les voyageurs depuis cent ans. "
  insightJournal: "Le tavernier cultive la tradition de sa famille en continuant
    \xE0 produire la recette de vin au miel de son arri\xE8re-grand-p\xE8re. Qui
    sait, si notre relation grandit, peut-\xEAtre qu'un jour j'en saurai plus sur
    le secret du vin. "
  imageJournal: {fileID: 21300000, guid: 510bf4090227f614f9f4efa4395367b0, type: 3}
  sonRamasser: {fileID: 8300000, guid: 3d692ceca3e2fbc4cbea3ecacb407ba6, type: 3}
  idActionADeclencher: objet_ramasse
